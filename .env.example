# =============================================================================
# Prose Arc — Environment Variables
# Copy to .env and fill in values for local development.
# Never commit .env to version control.
# =============================================================================

# -------------------------
# Database
# -------------------------
DATABASE_URL=postgresql+asyncpg://prosearc:prosearc@localhost:5533/prosearc

# -------------------------
# Redis
# -------------------------
REDIS_URL=redis://localhost:6480/0

# -------------------------
# Object Storage
# Use "minio" for local dev, "gcs" for production
# -------------------------
STORAGE_BACKEND=minio

# MinIO (local dev)
MINIO_ENDPOINT=localhost:9100
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prosearc
MINIO_USE_SSL=false

# GCS (production)
GCS_BUCKET=prosearc-prod
GCS_CREDENTIALS_PATH=  # path to service account JSON

# -------------------------
# Authentication / JWT
# -------------------------
JWT_SECRET=dev-secret-change-in-prod-use-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -------------------------
# Google OAuth
# Get from https://console.cloud.google.com/apis/credentials
# -------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -------------------------
# Stripe (Phase 1e — leave empty for now)
# -------------------------
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_CORE=price_
STRIPE_PRICE_AI_STARTER=price_
STRIPE_PRICE_AI_PRO=price_

# -------------------------
# AI Keys (Phase 2a — leave empty for now)
# -------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -------------------------
# Celery
# -------------------------
CELERY_BROKER_URL=redis://localhost:6480/1
CELERY_RESULT_BACKEND=redis://localhost:6480/2

# -------------------------
# Application
# -------------------------
APP_ENV=development
APP_URL=http://localhost:3100
API_URL=http://localhost:8100
CORS_ORIGINS=http://localhost:3100
